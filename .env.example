# BugIntel Frontend Environment Configuration

# API Configuration
# For development with Next.js mock API
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# For development with Django backend
NEXT_PUBLIC_DJANGO_API_URL=http://localhost:8000/api
NEXT_PUBLIC_USE_DJANGO=false

# For production
# NEXT_PUBLIC_API_URL=https://api.bugintel.app/api
# NEXT_PUBLIC_USE_DJANGO=true

# Feature Flags
NEXT_PUBLIC_ENABLE_DARK_MODE=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Debug
DEBUG=false
